# Docker Compose Environment Toggle (dev / prod)
COMPOSE_ENV=prod

# Project Prefix/Name for Container Naming
PROJECT_NAME=fod

# Database Configuration (Production)
DB_USER=postgres
# IMPORTANT: Change this password in production!
DB_PASSWORD=production_secure_password_replace_me
DB_NAME=fod_prod

# API Service Configuration
PORT=3001

# Next.js Frontend Configuration
WEB_PORT=3000
# Update this to your production API domain:
NEXT_PUBLIC_API_URL="http://localhost:3001"
