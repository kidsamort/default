{
  "name": "{{PROJECT_NAME}}",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "bun run clean && turbo dev",
    "clean": "fuser -k 3000/tcp 3001/tcp 3002/tcp || true",
    "lint": "turbo lint",
    "format": "biome format --write .",
    "db:generate": "turbo db:generate",
    "db:push": "turbo db:push",
    "init": "bun run scripts/init.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "consola": "^3.4.2",
    "turbo": "^2.8.20",
    "typescript": "^6.0.2"
  }
}
