{
  "name": "{{PROJECT_NAME}}",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "react": "^19.2.4",
      "react-dom": "^19.2.4",
      "typescript": "^6.0.2",
      "zustand": "^5.0.14",
      "lucide-react": "^1.7.0",
      "@radix-ui/themes": "^3.3.0",
      "consola": "^3.4.2"
    },
    "catalogs": {
      "db": {
        "drizzle-orm": "^0.38.0",
        "postgres": "^3.4.5",
        "drizzle-kit": "^0.30.0"
      },
      "build": {
        "turbo": "^2.8.20",
        "@biomejs/biome": "^2.4.9"
      }
    }
  },
  "scripts": {
    "build": "turbo build",
    "dev": "bun run clean && turbo dev",
    "clean": "fuser -k 3000/tcp 3001/tcp 3002/tcp || true",
    "lint": "turbo lint",
    "lint:fix": "biome check --write --unsafe .",
    "format": "biome format --write .",
    "db:generate": "turbo db:generate",
    "db:push": "turbo db:push",
    "init": "bun run scripts/init.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "consola": "^3.4.2",
    "turbo": "^2.8.20",
    "typescript": "^6.0.2"
  }
}
